---
import Base from "../layouts/Base.astro";
---
<Base title="Home">
	<div class="page-header">
		<h2>Welcome</h2>
		<p>
			Self-service portal for the <strong>r2-event-feed</strong> pipeline. Create a
			Subscriber tenant, mint R2 read tokens, and configure webhook / pull-queue /
			SSE subscriptions against the operator's source bucket.
		</p>
	</div>

	<div class="card" id="me-card">
		<h2>Your account</h2>
		<p class="muted">Signed in via Cloudflare Access. Anyone allowed by the Access policy is auto-approved as a subscriber on first enrolment.</p>
		<div id="me-detail" class="muted">Loading account…</div>
	</div>

	<div class="card" id="enrol-card" hidden>
		<h2>Create a Subscriber tenant</h2>
		<p class="muted">
			Subscribers are the tenants that receive R2 events. Create one for yourself so
			you can mint tokens and configure subscriptions.
		</p>
		<label for="name">Subscriber name</label>
		<input id="name" placeholder="Acme Corp" autocomplete="organization" />
		<div class="actions">
			<button id="enrol-btn">Create Subscriber</button>
		</div>
		<div id="enrol-result" class="result"></div>
	</div>

	<script>
		function show(elId: string, value: unknown) {
			const el = document.getElementById(elId);
			if (el) el.innerHTML = `<pre>${JSON.stringify(value, null, 2)}</pre>`;
		}

		async function refresh() {
			const me = await fetch("/api/me").then((r) => r.json()).catch(() => null);
			const detail = document.getElementById("me-detail")!;
			const enrolCard = document.getElementById("enrol-card")!;
			if (!me || !me.user) {
				detail.innerHTML = `<p class="muted">Not authenticated. Make sure Cloudflare Access is configured for this app.</p>`;
				return;
			}
			const sub = me.subscriber
				? `<strong>${me.subscriber.name}</strong> <span class="tag ${me.subscriber.status === "approved" ? "ok" : "warn"}">${me.subscriber.status}</span>`
				: `<span class="soft">— no subscriber tenant yet —</span>`;
			detail.innerHTML = `
				<table class="kv">
					<tr><th>Email</th><td>${me.user.email}</td></tr>
					<tr><th>Role</th><td><span class="tag brand">${me.user.role}</span></td></tr>
					<tr><th>Subscriber</th><td>${sub}</td></tr>
				</table>`;
			if (!me.user.subscriber_id) enrolCard.hidden = false;
		}

		document.getElementById("enrol-btn")?.addEventListener("click", async () => {
			const name = (document.getElementById("name") as HTMLInputElement).value.trim();
			if (!name) return alert("Please provide a name.");
			const res = await fetch("/api/enrol", {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify({ name }),
			}).then((r) => r.json());
			show("enrol-result", res);
			refresh();
		});

		refresh();
	</script>
</Base>
