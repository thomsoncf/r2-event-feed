---
import Base from "../layouts/Base.astro";
---
<Base title="Home">
	<div class="card">
		<h2>Welcome</h2>
		<p>
			This is the <strong>r2-event-feed</strong> self-service portal. Use it to create a
			Subscriber tenant, mint R2 read tokens, and create webhook / pull-queue / SSE
			subscriptions against the operator's R2 bucket.
		</p>
		<p class="muted">
			You should be signed in via Cloudflare Access. If you don't have a Subscriber
			tenant yet, the <strong>Create a Subscriber tenant</strong> card below will let
			you create one. Anyone who can sign in is auto-approved.
		</p>
	</div>

	<div class="card" id="me-card">
		<h2>Your account</h2>
		<div id="me-detail">Loading…</div>
	</div>

	<div class="card" id="enrol-card" hidden>
		<h2>Create a Subscriber tenant</h2>
		<p class="muted">
			Subscribers are the tenants that receive R2 events. Create one for yourself
			so you can mint R2 read tokens and create webhook / pull-queue / SSE
			subscriptions against the source bucket.
		</p>
		<label for="name">Subscriber name</label>
		<input id="name" placeholder="Acme Corp" />
		<p>
			<button id="enrol-btn">Create Subscriber</button>
		</p>
	</div>

	<script>
		async function refresh() {
			const me = await fetch("/api/me").then((r) => r.json()).catch(() => null);
			const detail = document.getElementById("me-detail")!;
			const enrolCard = document.getElementById("enrol-card")!;
			if (!me || !me.user) {
				detail.innerHTML = `<p class="muted">Not authenticated. Make sure Cloudflare Access is configured for this app.</p>`;
				return;
			}
			detail.innerHTML = `
				<table>
					<tr><th>Email</th><td>${me.user.email}</td></tr>
					<tr><th>Role</th><td>${me.user.role}</td></tr>
					<tr><th>Subscriber</th><td>${me.subscriber ? `${me.subscriber.name} <span class="tag ${me.subscriber.status === "approved" ? "ok" : "warn"}">${me.subscriber.status}</span>` : "—"}</td></tr>
				</table>`;
			// Anyone authenticated but not yet linked to a Subscriber can create one.
			// Operators (operator_admin) can also do this — see /api/enrol on the backend.
			if (!me.user.subscriber_id) {
				enrolCard.hidden = false;
			}
		}

		document.getElementById("enrol-btn")?.addEventListener("click", async () => {
			const name = (document.getElementById("name") as HTMLInputElement).value.trim();
			if (!name) return alert("Please provide a name.");
			const res = await fetch("/api/enrol", {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify({ name }),
			});
			const body = await res.json();
			alert(JSON.stringify(body, null, 2));
			refresh();
		});

		refresh();
	</script>
</Base>
