{
	"name": "r2-event-feed",
	"version": "0.1.0",
	"private": true,
	"description": "Self-service R2 → Queues → Workers fan-out demo with webhook, pull-queue and SSE/WebSocket delivery channels.",
	"license": "Unlicense",
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"test": "turbo run test",
		"lint": "biome check .",
		"format": "biome format --write .",
		"check-types": "turbo run check-types",
		"up:all": "pnpm up --latest -r"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"sharp",
			"workerd"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@cloudflare/workers-types": "^4.20260426.1",
		"turbo": "^2.9.6",
		"typescript": "^5.7.3",
		"vitest": "^2.1.8",
		"wrangler": "^4.86.0"
	},
	"packageManager": "pnpm@10.33.0"
}
