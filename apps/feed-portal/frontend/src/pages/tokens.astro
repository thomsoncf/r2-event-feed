---
import Base from "../layouts/Base.astro";
---
<Base title="Tokens & Subscriptions">
	<div class="page-header">
		<h2>Tokens &amp; Subscriptions</h2>
		<p>Mint R2 read tokens, and create delivery subscriptions across the three supported channels.</p>
	</div>

	<div class="card">
		<h2>R2 read tokens</h2>
		<p class="muted">Bucket-scoped, read-only. Returned as an S3-compatible credential pair. <strong>Shown once</strong>.</p>
		<label for="r2-label">Label</label>
		<input id="r2-label" placeholder="prod read-only" />
		<div class="actions">
			<button id="mint-r2">Mint R2 token</button>
		</div>
		<div id="r2-result" class="result"></div>
		<div class="table-wrap" style="margin-top: 16px">
			<table id="r2-table">
				<thead><tr><th>ID</th><th>Label</th><th>Created</th><th></th></tr></thead>
				<tbody></tbody>
			</table>
		</div>
	</div>

	<div class="grid-2">
		<div class="card">
			<h2>Webhook subscription</h2>
			<p class="muted">HMAC-signed POST to your HTTPS endpoint. The signing secret is shown <strong>once</strong>.</p>
			<label for="webhook-url">HTTPS URL</label>
			<input id="webhook-url" placeholder="https://example.com/r2-events" inputmode="url" />
			<div class="actions">
				<button id="create-webhook">Create webhook</button>
			</div>
			<div id="webhook-result" class="result"></div>
		</div>

		<div class="card">
			<h2>Topic-based SSE / WebSocket</h2>
			<p class="muted">Long-lived stream key (JWT). Connect to <code>/stream?key=…</code> on the fanout worker for SSE, or <code>/ws?key=…</code> for WebSocket.</p>
			<div class="actions">
				<button id="create-stream">Create stream key</button>
			</div>
			<div id="stream-result" class="result"></div>
		</div>
	</div>

	<div class="card">
		<h2>Active subscriptions</h2>
		<div class="table-wrap">
			<table id="subs-table">
				<thead><tr><th>ID</th><th>Channel</th><th>Target</th><th>Status</th><th></th></tr></thead>
				<tbody></tbody>
			</table>
		</div>
	</div>

	<script>
		function show(elId: string, value: unknown) {
			const el = document.getElementById(elId);
			if (el) el.innerHTML = `<pre>${JSON.stringify(value, null, 2)}</pre>`;
		}

		function shortId(id: string) {
			return id.length > 16 ? id.slice(0, 12) + "…" : id;
		}

		function ts(secs: number) {
			return new Date(secs * 1000).toISOString().replace("T", " ").slice(0, 19) + " UTC";
		}

		function emptyRow(cols: number, msg: string) {
			return `<tr><td colspan="${cols}"><div class="empty">${msg}</div></td></tr>`;
		}

		async function refresh() {
			const tokens = await fetch("/api/r2-tokens").then((r) => r.json()).catch(() => ({ tokens: [] }));
			const tbody = document.querySelector("#r2-table tbody")!;
			const tokenRows = tokens.tokens ?? [];
			tbody.innerHTML = tokenRows.length === 0
				? emptyRow(4, "No tokens minted yet.")
				: tokenRows.map((t: any) => {
					const revoked = t.revoked_at !== null && t.revoked_at !== undefined;
					return `<tr>
						<td><code>${shortId(t.id)}</code></td>
						<td>${t.label ?? ""} ${revoked ? '<span class="tag bad">revoked</span>' : '<span class="tag ok">active</span>'}</td>
						<td class="muted">${ts(t.created_at)}</td>
						<td style="text-align:right">${revoked ? "" : `<button class="secondary revoke-r2" data-id="${t.id}">Revoke</button>`}</td>
					</tr>`;
				}).join("");
			tbody.querySelectorAll<HTMLButtonElement>(".revoke-r2").forEach((b) => {
				b.onclick = async () => {
					b.disabled = true;
					await fetch(`/api/r2-tokens/${b.dataset.id}`, { method: "DELETE" });
					refresh();
				};
			});

			const subs = await fetch("/api/subscriptions").then((r) => r.json()).catch(() => ({ subscriptions: [] }));
			const sbody = document.querySelector("#subs-table tbody")!;
			const subRows = subs.subscriptions ?? [];
			sbody.innerHTML = subRows.length === 0
				? emptyRow(5, "No subscriptions yet. Create one above.")
				: subRows.map((s: any) => {
					const cleanChannel = s.channel === "sse" ? "stream" : s.channel;
					const label = s.channel === "sse" ? "SSE / WS" : "Webhook";
					return `<tr>
						<td>${s.id}</td>
						<td>${label}</td>
						<td><code>${s.target}</code></td>
						<td><span class="tag ${s.status === "active" ? "ok" : "bad"}">${s.status}</span></td>
						<td style="text-align:right">${s.status === "active" ? `<button class="secondary revoke-sub" data-id="${s.id}" data-ch="${cleanChannel}">Revoke</button>` : ""}</td>
					</tr>`;
				}).join("");
			sbody.querySelectorAll<HTMLButtonElement>(".revoke-sub").forEach((b) => {
				b.onclick = async () => {
					b.disabled = true;
					await fetch(`/api/subscriptions/${b.dataset.ch}/${b.dataset.id}`, { method: "DELETE" });
					refresh();
				};
			});
		}

		document.getElementById("mint-r2")!.onclick = async () => {
			const btn = document.getElementById("mint-r2") as HTMLButtonElement;
			btn.disabled = true;
			const label = (document.getElementById("r2-label") as HTMLInputElement).value;
			const res = await fetch("/api/r2-tokens", {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify({ label }),
			}).then((r) => r.json());
			show("r2-result", res);
			btn.disabled = false;
			refresh();
		};

		document.getElementById("create-webhook")!.onclick = async () => {
			const btn = document.getElementById("create-webhook") as HTMLButtonElement;
			btn.disabled = true;
			const url = (document.getElementById("webhook-url") as HTMLInputElement).value;
			const res = await fetch("/api/subscriptions/webhook", {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify({ url }),
			}).then((r) => r.json());
			show("webhook-result", res);
			btn.disabled = false;
			refresh();
		};

		document.getElementById("create-stream")!.onclick = async () => {
			const btn = document.getElementById("create-stream") as HTMLButtonElement;
			btn.disabled = true;
			const res = await fetch("/api/subscriptions/stream", { method: "POST" }).then((r) => r.json());

			// Stash the stream key in sessionStorage so /feed/ can use it
			// without the user having to paste it. Tab-scoped: clearing the
			// tab clears the keys.
			if (res && res.stream_key && res.id) {
				try {
					const all = JSON.parse(sessionStorage.getItem("r2ef.streamKeys") ?? "{}");
					all[String(res.id)] = {
						id: res.id,
						kid: res.kid,
						sse_url: res.sse_url,
						ws_url: res.ws_url,
						stream_key: res.stream_key,
					};
					sessionStorage.setItem("r2ef.streamKeys", JSON.stringify(all));
				} catch {}
			}

			const out = document.getElementById("stream-result")!;
			out.innerHTML = `
				<pre>${JSON.stringify(res, null, 2)}</pre>
				<div class="actions">
					<a class="open-feed-link" href="/feed/#sub=${res.id}"><button>Open in Live Feed →</button></a>
				</div>`;
			btn.disabled = false;
			refresh();
		};

		refresh();
	</script>
</Base>
