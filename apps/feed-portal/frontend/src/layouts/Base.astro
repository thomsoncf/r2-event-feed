---
interface Props {
	title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="color-scheme" content="light dark" />
		<title>{title} · r2-event-feed</title>
		<style>
			:root {
				--bg: #f8fafc;
				--bg-elev: #ffffff;
				--bg-soft: #f1f5f9;
				--border: #d4dae3;
				--border-strong: #b7c0cd;
				--text: #0f172a;
				--text-muted: #64748b;
				--text-soft: #94a3b8;
				--brand: #f48120;
				--brand-hover: #d96d10;
				--brand-soft: #fff7ed;
				--accent: #2563eb;
				--ok: #16a34a;
				--ok-bg: #dcfce7;
				--warn: #ca8a04;
				--warn-bg: #fef9c3;
				--bad: #dc2626;
				--bad-bg: #fee2e2;
				--shadow-sm: 0 1px 2px rgba(15, 23, 42, 0.04);
				--shadow-md: 0 1px 3px rgba(15, 23, 42, 0.06), 0 1px 2px rgba(15, 23, 42, 0.04);
				--shadow-lg: 0 4px 12px rgba(15, 23, 42, 0.08), 0 2px 4px rgba(15, 23, 42, 0.04);
				--radius-sm: 6px;
				--radius: 10px;
				--radius-lg: 14px;
				--font-sans: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
					Roboto, "Helvetica Neue", Arial, "Noto Sans", sans-serif;
				--font-mono: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, "Liberation Mono",
					monospace;
			}

			* { box-sizing: border-box; }
			html { -webkit-text-size-adjust: 100%; }

			body {
				margin: 0;
				background: var(--bg);
				color: var(--text);
				font-family: var(--font-sans);
				font-size: 14px;
				line-height: 1.55;
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
			}

			/* ───── header ───── */
			header {
				background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
				color: #fff;
				padding: 20px 32px;
				border-bottom: 3px solid var(--brand);
				display: flex;
				align-items: center;
				justify-content: space-between;
			}
			header .brand {
				display: flex;
				align-items: center;
				gap: 12px;
			}
			header .logo-dot {
				width: 10px;
				height: 10px;
				border-radius: 50%;
				background: var(--brand);
				box-shadow: 0 0 12px rgba(244, 129, 32, 0.6);
			}
			header h1 {
				margin: 0;
				font-size: 16px;
				font-weight: 600;
				letter-spacing: -0.01em;
			}
			header .tagline {
				color: #94a3b8;
				font-size: 12px;
				font-weight: 400;
			}

			/* ───── nav ───── */
			nav {
				background: var(--bg-elev);
				border-bottom: 1px solid var(--border);
				padding: 0 32px;
				display: flex;
				gap: 4px;
				overflow-x: auto;
				position: sticky;
				top: 0;
				z-index: 10;
				backdrop-filter: saturate(180%) blur(8px);
				background: rgba(255, 255, 255, 0.85);
			}
			nav a {
				display: inline-block;
				padding: 14px 16px;
				color: var(--text-muted);
				text-decoration: none;
				font-weight: 500;
				font-size: 13px;
				border-bottom: 2px solid transparent;
				transition: color 0.15s, border-color 0.15s;
				white-space: nowrap;
			}
			nav a:hover { color: var(--text); }
			nav a.active {
				color: var(--text);
				border-bottom-color: var(--brand);
			}

			/* ───── main ───── */
			main {
				max-width: 1040px;
				margin: 0 auto;
				padding: 32px;
			}
			main > h2:first-child,
			main > .page-header {
				margin-top: 0;
			}
			.page-header {
				margin-bottom: 20px;
			}
			.page-header h2 {
				font-size: 22px;
				font-weight: 600;
				letter-spacing: -0.02em;
				margin: 0 0 4px;
			}
			.page-header p {
				color: var(--text-muted);
				margin: 0;
			}

			/* ───── cards ───── */
			.card {
				background: var(--bg-elev);
				border: 1px solid var(--border);
				border-radius: var(--radius);
				padding: 24px 28px;
				margin-bottom: 16px;
				box-shadow: var(--shadow-sm);
			}
			.card h2 {
				margin: 0 0 4px;
				font-size: 15px;
				font-weight: 600;
				letter-spacing: -0.005em;
				color: var(--text);
			}
			.card h2 + p,
			.card h2 + p.muted {
				margin-top: 0;
				margin-bottom: 16px;
			}
			.grid-2 {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 16px;
			}
			.grid-2 .card { margin-bottom: 0; }
			@media (max-width: 720px) {
				.grid-2 { grid-template-columns: 1fr; }
				main { padding: 20px; }
				nav { padding: 0 20px; }
				header { padding: 18px 20px; }
			}

			/* ───── typography helpers ───── */
			h1, h2, h3 { line-height: 1.3; }
			p { margin: 8px 0; }
			.muted { color: var(--text-muted); font-size: 13px; }
			.soft  { color: var(--text-soft); }
			code, .mono {
				font-family: var(--font-mono);
				font-size: 0.92em;
			}
			:not(pre) > code {
				background: var(--bg-soft);
				padding: 2px 6px;
				border-radius: 4px;
				border: 1px solid var(--border);
				color: var(--text);
			}
			a { color: var(--accent); }

			/* ───── buttons ───── */
			button {
				appearance: none;
				background: var(--brand);
				color: #fff;
				border: 1px solid transparent;
				padding: 9px 16px;
				border-radius: var(--radius-sm);
				font: inherit;
				font-weight: 500;
				font-size: 13px;
				cursor: pointer;
				transition: background 0.12s, box-shadow 0.12s, transform 0.04s;
				box-shadow: var(--shadow-sm);
			}
			button:hover {
				background: var(--brand-hover);
				box-shadow: var(--shadow-md);
			}
			button:active { transform: translateY(1px); }
			button:focus-visible {
				outline: 2px solid var(--brand);
				outline-offset: 2px;
			}
			button.secondary {
				background: var(--bg-elev);
				color: var(--text);
				border-color: var(--border-strong);
			}
			button.secondary:hover {
				background: var(--bg-soft);
				border-color: var(--text-muted);
			}
			button.danger {
				background: var(--bad);
				border-color: transparent;
			}
			button.danger:hover { background: #b91c1c; }
			button + button { margin-left: 8px; }

			/* ───── inputs ───── */
			label {
				display: block;
				font-weight: 500;
				font-size: 13px;
				margin: 14px 0 6px;
				color: var(--text);
			}
			label:first-child { margin-top: 0; }
			input, select, textarea {
				background: var(--bg-elev);
				border: 1px solid var(--border-strong);
				padding: 9px 12px;
				border-radius: var(--radius-sm);
				font: inherit;
				font-size: 13px;
				color: var(--text);
				width: 100%;
				max-width: 520px;
				transition: border-color 0.12s, box-shadow 0.12s;
			}
			input::placeholder { color: var(--text-soft); }
			input:focus, select:focus, textarea:focus {
				outline: none;
				border-color: var(--brand);
				box-shadow: 0 0 0 3px rgba(244, 129, 32, 0.15);
			}

			/* ───── pre/code blocks ───── */
			pre {
				background: #0f172a;
				color: #e2e8f0;
				border: 1px solid #1e293b;
				padding: 14px 16px;
				border-radius: var(--radius-sm);
				overflow-x: auto;
				font-size: 12px;
				line-height: 1.5;
				font-family: var(--font-mono);
				margin: 12px 0;
			}
			pre code {
				background: none;
				border: none;
				padding: 0;
				color: inherit;
			}

			/* ───── tables ───── */
			.table-wrap {
				overflow-x: auto;
				border: 1px solid var(--border-strong);
				border-radius: var(--radius-sm);
				background: var(--bg-elev);
			}
			table {
				width: 100%;
				border-collapse: collapse;
				font-size: 13px;
			}
			th, td {
				padding: 11px 14px;
				text-align: left;
				vertical-align: middle;
				border-bottom: 1px solid var(--border);
			}
			thead th {
				background: var(--bg-soft);
				color: var(--text-muted);
				font-weight: 600;
				font-size: 11px;
				text-transform: uppercase;
				letter-spacing: 0.04em;
				border-bottom: 2px solid var(--border-strong);
				position: sticky;
				top: 0;
			}
			/* Column separators — subtle, just enough to make it look like a table */
			tbody td + td,
			thead th + th {
				border-left: 1px solid var(--border);
			}
			tbody tr {
				transition: background 0.08s;
			}
			tbody tr:last-child td { border-bottom: 0; }
			tbody tr:hover { background: var(--bg-soft); }
			td code { font-size: 12px; }

			/* The "key-value" tables (no thead, th in first column).
			   Wrap them in their own bordered frame too. */
			table.kv {
				border: 1px solid var(--border-strong);
				border-radius: var(--radius-sm);
				overflow: hidden;
				background: var(--bg-elev);
			}
			table.kv th {
				background: var(--bg-soft);
				color: var(--text-muted);
				text-transform: none;
				letter-spacing: 0;
				font-size: 13px;
				font-weight: 600;
				width: 160px;
				border-bottom: 1px solid var(--border);
				border-right: 1px solid var(--border);
				position: static;
			}
			table.kv td {
				border-bottom: 1px solid var(--border);
			}
			table.kv tr:last-child th,
			table.kv tr:last-child td {
				border-bottom: 0;
			}

			/* ───── tags ───── */
			.tag {
				display: inline-block;
				padding: 2px 9px;
				border-radius: 999px;
				font-size: 11px;
				font-weight: 600;
				line-height: 1.5;
				letter-spacing: 0.01em;
				border: 1px solid transparent;
			}
			.tag.ok   { background: var(--ok-bg);   color: var(--ok);   border-color: rgba(22, 163, 74, 0.2); }
			.tag.warn { background: var(--warn-bg); color: var(--warn); border-color: rgba(202, 138, 4, 0.2); }
			.tag.bad  { background: var(--bad-bg);  color: var(--bad);  border-color: rgba(220, 38, 38, 0.2); }
			.tag.brand{ background: var(--brand-soft); color: var(--brand); border-color: rgba(244, 129, 32, 0.25); }

			/* ───── result panel (after a successful action) ───── */
			.result {
				margin-top: 14px;
			}
			.result:empty { display: none; }

			/* ───── form row helpers ───── */
			.actions {
				margin-top: 16px;
				display: flex;
				gap: 8px;
				flex-wrap: wrap;
			}
			.actions button { margin-left: 0; }

			/* ───── empty state ───── */
			.empty {
				text-align: center;
				color: var(--text-soft);
				padding: 32px 16px;
				font-size: 13px;
			}

			/* ───── status badge in nav (footer-ish) ───── */
			.footer {
				max-width: 1040px;
				margin: 32px auto 48px;
				padding: 0 32px;
				color: var(--text-soft);
				font-size: 12px;
				display: flex;
				justify-content: space-between;
				flex-wrap: wrap;
				gap: 8px;
			}
			.footer a { color: var(--text-muted); text-decoration: none; }
			.footer a:hover { color: var(--text); text-decoration: underline; }

			@media (prefers-color-scheme: dark) {
				:root {
					--bg: #0b1120;
					--bg-elev: #111827;
					--bg-soft: #1e293b;
					--border: #1e293b;
					--border-strong: #334155;
					--text: #f1f5f9;
					--text-muted: #94a3b8;
					--text-soft: #64748b;
					--brand-soft: rgba(244, 129, 32, 0.12);
				}
				nav { background: rgba(17, 24, 39, 0.85); }
				pre { background: #020617; border-color: #1e293b; }
				:not(pre) > code {
					background: var(--bg-soft);
					border-color: var(--border-strong);
				}
			}
		</style>
	</head>
	<body>
		<header>
			<div class="brand">
				<span class="logo-dot"></span>
				<h1>r2-event-feed</h1>
			</div>
			<span class="tagline">R2 → Queue → Workers fan-out</span>
		</header>
		<nav id="primary-nav">
			<a href="/" data-path="/">Home</a>
			<a href="/tokens/" data-path="/tokens/">Tokens & Subscriptions</a>
			<a href="/feed/" data-path="/feed/">Live Feed</a>
			<a href="/admin/approvals/" data-path="/admin/approvals/">Admin</a>
		</nav>
		<main>
			<slot />
		</main>
		<footer class="footer">
			<span>r2-event-feed · <a href="https://github.com/thomsoncf/r2-event-feed">github</a></span>
			<span>Public domain · Unlicense</span>
		</footer>
		<script>
			// Highlight the active nav item.
			const here = location.pathname.replace(/\/+$/, "/") || "/";
			document.querySelectorAll<HTMLAnchorElement>("#primary-nav a").forEach((a) => {
				const p = a.dataset.path || a.getAttribute("href") || "";
				if (p === here || (p !== "/" && here.startsWith(p))) a.classList.add("active");
			});
		</script>
	</body>
</html>
